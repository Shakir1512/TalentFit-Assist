# TalentFit Assist Environment Configuration
# Copy this to .env and update with your values

# ========== DATABASE ==========
DATABASE_URL=postgresql://talentfit_user:secure_password@localhost:5432/talentfit_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# ========== JWT & SECURITY ==========
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=1

# ========== LLM PROVIDERS ==========
# Anthropic (Primary)
ANTHROPIC_API_KEY=sk-ant-v1-xxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# OpenAI (Secondary)
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4-turbo

# Azure OpenAI (Optional)
AZURE_OPENAI_KEY=your-azure-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# ========== EMBEDDING SERVICE ==========
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# ========== VECTOR DATABASE ==========
CHROMADB_HOST=localhost
CHROMADB_PORT=6333
CHROMADB_COLLECTION_JD=jd_chunks
CHROMADB_COLLECTION_RESUME=resume_chunks
CHROMADB_COLLECTION_POLICY=policy_chunks

# ========== CACHE ==========
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
CACHE_TTL_SECONDS=300

# ========== STORAGE ==========
# Local development
STORAGE_TYPE=local
LOCAL_STORAGE_PATH=./data/documents

# AWS S3 (Production)
AWS_S3_BUCKET=talentfit-documents
AWS_S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ========== CONFIGURATION ==========
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=300
LLM_TOP_P=0.9

CHUNK_SIZE_JD=256
CHUNK_OVERLAP_JD=50
CHUNK_SIZE_RESUME=128
CHUNK_OVERLAP_RESUME=30
CHUNK_SIZE_POLICY=512
CHUNK_OVERLAP_POLICY=100

TOP_K_RETRIEVAL=5
RAG_SIMILARITY_THRESHOLD=0.5
MAX_CONTEXT_TOKENS=2000

# Scoring weights (must sum to 1.0)
SCORE_WEIGHT_MUST_HAVE=0.4
SCORE_WEIGHT_NICE_TO_HAVE=0.2
SCORE_WEIGHT_EXPERIENCE=0.2
SCORE_WEIGHT_DOMAIN=0.1
SCORE_WEIGHT_AMBIGUITY=0.1

# ========== COST & BUDGET ==========
MONTHLY_TOKEN_BUDGET=500000
COST_ALERT_THRESHOLD_PERCENT=80

# Pricing (USD per 1k tokens)
CLAUDE_COST_INPUT_PER_1K=0.003
CLAUDE_COST_OUTPUT_PER_1K=0.015
GPT4_COST_INPUT_PER_1K=0.03
GPT4_COST_OUTPUT_PER_1K=0.06

# ========== GUARDRAILS ==========
GUARDRAIL_STRICTNESS=HIGH
REQUIRE_CITATIONS=true
BLOCK_ON_PROTECTED_ATTRIBUTES=true
MAX_HALLUCINATION_SCORE=0.8

# ========== LOGGING & MONITORING ==========
LOG_LEVEL=INFO
LOG_FORMAT=json
SENTRY_DSN=
DATADOG_API_KEY=

# ========== DEPLOYMENT ==========
ENVIRONMENT=development
DEBUG=false
ALLOW_ORIGINS="*"

# ========== OPTIONAL: OKTA/OAUTH2 ==========
OAUTH_PROVIDER=okta
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_AUTHORIZE_URL=
OAUTH_TOKEN_URL=

# ========== OPTIONAL: MCP SERVER ==========
MCP_SERVER_HOST=localhost
MCP_SERVER_PORT=8888
MCP_SERVER_API_KEY=your-mcp-api-key
